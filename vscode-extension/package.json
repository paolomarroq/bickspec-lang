{
  "name": "bickspec-finance-dsl",
  "displayName": "BickSpec Finance DSL",
  "description": "Professional VS Code support for BickSpec, a finance and economic engineering DSL with compiler integration.",
  "version": "0.3.0",
  "publisher": "bickspec",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/paolomarroq/bickspec-lang.git"
  },
  "icon": "media/bickspec-icon.png",
  "main": "./extension.js",
  "engines": {
    "vscode": "^1.90.0"
  },
  "extensionKind": [
    "workspace"
  ],
  "scripts": {
    "check": "node --check extension.js",
    "prepare:compiler": "node scripts/prepare-compiler.js",
    "package": "npm run prepare:compiler && vsce package",
    "package:vsix": "npm run prepare:compiler && vsce package"
  },
  "files": [
    "media/compiler/**",
    "media/docs/**",
    "media/wizard/**",
    "media/bickspec-icon.png",
    "media/bickspec-icon.svg",
    "setup/**",
    "syntaxes/**",
    "snippets/**",
    "themes/**",
    "scripts/**",
    "language-configuration.json",
    "compilerResolver.js",
    "extension.js",
    "README.md",
    "package.json"
  ],
  "devDependencies": {
    "@vscode/vsce": "^3.6.2"
  },
  "galleryBanner": {
    "color": "#0F274A",
    "theme": "dark"
  },
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:bickspec",
    "onCommand:bickspec.openDocumentation",
    "onCommand:bickspec.openSetupWizard",
    "onCommand:bickspec.validateEnvironment",
    "onCommand:bickspec.selectCompilerJar",
    "onCommand:bickspec.selectCompilerRepo",
    "onCommand:bickspec.runSetupTest",
    "onCommand:bickspec.resetSetup",
    "onCommand:bickspec.runCurrentFile",
    "onCommand:bickspec.runFolder",
    "onCommand:bickspec.showCompilerOutput",
    "onCommand:bickspec.openGeneratedJava",
    "onCommand:bickspec.openSymbolTable",
    "onCommand:bickspec.openParseTreeSvg"
  ],
  "categories": [
    "Programming Languages",
    "Snippets",
    "Themes"
  ],
    "keywords": [
    "bickspec",
    "dsl",
    "finance",
    "economic engineering",
    "antlr"
  ],
  "contributes": {
    "languages": [
      {
        "id": "bickspec",
        "aliases": [
          "BickSpec",
          "bickspec"
        ],
        "extensions": [
          ".bks"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "bickspec",
        "scopeName": "source.bickspec",
        "path": "./syntaxes/bickspec.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "bickspec",
        "path": "./snippets/bickspec.code-snippets"
      }
    ],
    "themes": [
      {
        "label": "BickSpec Academic",
        "uiTheme": "vs",
        "path": "./themes/bickspec-academic-color-theme.json"
      }
    ],
    "commands": [
      {
        "command": "bickspec.runCurrentFile",
        "title": "BickSpec: Run Current File",
        "category": "BickSpec"
      },
      {
        "command": "bickspec.runFolder",
        "title": "BickSpec: Run Folder",
        "category": "BickSpec"
      },
      {
        "command": "bickspec.showCompilerOutput",
        "title": "BickSpec: Show Compiler Output",
        "category": "BickSpec"
      },
      {
        "command": "bickspec.openGeneratedJava",
        "title": "BickSpec: Open Generated Java",
        "category": "BickSpec"
      },
      {
        "command": "bickspec.openSymbolTable",
        "title": "BickSpec: Open Symbol Table CSV",
        "category": "BickSpec"
      },
      {
        "command": "bickspec.openParseTreeSvg",
        "title": "BickSpec: Open Parse Tree SVG",
        "category": "BickSpec"
      },
      {
        "command": "bickspec.openDocumentation",
        "title": "BickSpec: Open Documentation",
        "category": "BickSpec"
      },
      {
        "command": "bickspec.openSetupWizard",
        "title": "BickSpec: Open Setup Wizard",
        "category": "BickSpec"
      },
      {
        "command": "bickspec.validateEnvironment",
        "title": "BickSpec: Validate Environment",
        "category": "BickSpec"
      },
      {
        "command": "bickspec.selectCompilerJar",
        "title": "BickSpec: Select Compiler JAR",
        "category": "BickSpec"
      },
      {
        "command": "bickspec.selectCompilerRepo",
        "title": "BickSpec: Select bickspec-lang Repository",
        "category": "BickSpec"
      },
      {
        "command": "bickspec.runSetupTest",
        "title": "BickSpec: Run Setup Test",
        "category": "BickSpec"
      },
      {
        "command": "bickspec.resetSetup",
        "title": "BickSpec: Reset Setup",
        "category": "BickSpec"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "bickspec.runCurrentFile",
          "when": "resourceExtname == .bks",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "bickspec.runCurrentFile",
          "when": "resourceExtname == .bks",
          "group": "bickspec@1"
        },
        {
          "command": "bickspec.runFolder",
          "when": "explorerResourceIsFolder",
          "group": "bickspec@2"
        }
      ]
    },
    "configuration": [
      {
        "title": "BickSpec",
        "properties": {
          "bickspec.compiler.jarPath": {
            "type": "string",
            "default": "",
            "description": "Optional custom path to bickspec-compiler-1.0.0.jar. Relative paths are resolved from the workspace folder. Leave empty to use the compiler bundled with the extension."
          },
          "bickspec.javaPath": {
            "type": "string",
            "default": "",
            "description": "Optional path to the Java executable. Leave empty to use java from PATH."
          },
          "bickspec.compiler.repoPath": {
            "type": "string",
            "default": "",
            "description": "Optional path to the local bickspec-lang repository for advanced clone/build workflows."
          },
          "bickspec.compiler.githubUrl": {
            "type": "string",
            "default": "https://github.com/paolomarroq/bickspec-lang",
            "description": "GitHub URL used when cloning the BickSpec compiler repository."
          },
          "bickspec.outputDirectory": {
            "type": "string",
            "default": "output",
            "description": "Compiler output directory, resolved from the workspace root when relative."
          },
          "bickspec.setup.completed": {
            "type": "boolean",
            "default": false,
            "description": "Whether the BickSpec setup wizard has completed successfully."
          },
          "bickspec.setup.autoOpenOnFirstLaunch": {
            "type": "boolean",
            "default": true,
            "description": "Prompt to open the setup wizard the first time BickSpec is activated."
          },
          "bickspec.documentation.openOnFirstActivation": {
            "type": "boolean",
            "default": true,
            "description": "Open the bundled BickSpec documentation once on the first extension activation."
          }
        }
      }
    ]
  }
}
